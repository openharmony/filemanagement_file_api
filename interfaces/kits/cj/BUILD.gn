import("//build/ohos.gni")
import("//foundation/filemanagement/file_api/file_api.gni")

config("js_common_config") {
  include_dirs = [
    "${src_path}/common",
    "${src_path}/common/file_helper",
    "${src_path}/mod_fs",
    "${src_path}/mod_fs/class_file",
    "${src_path}/mod_fs/class_randomaccessfile",
    "${src_path}/mod_fs/class_readeriterator",
    "${src_path}/mod_fs/class_stream",
    "${src_path}/mod_fs/properties",
    "${utils_path}/common/include",
    "${utils_path}/filemgmt_libhilog",
    "${utils_path}/filemgmt_libh",
    "${utils_path}/filemgmt_libn/include",
    "${utils_path}/filemgmt_libn/include/n_async",
  ]
}

ohos_source_set("js_common_src") {
  sanitize = {
    cfi = true
    cfi_cross_dso = true
    debug = false
  }
  sources = [
    "../js/src/common/file_helper/fd_guard.cpp",
    "../js/src/mod_fs/common_func.cpp",
    "../js/src/mod_fs/class_file/file_n_exporter.cpp",
  ]
  public_configs = [ ":js_common_config" ]
  cflags_cc = [
    "-std=c++17",
    "-fno-rtti",
    "-fmerge-all-constants",
    "-fomit-frame-pointer",
    "-flto",
  ]
  use_exceptions = true
  external_deps = [
    "ability_base:zuri",
    "ability_runtime:app_context",
    "access_token:libtokenid_sdk",
    "app_file_service:fileuri_native",
    "bundle_framework:appexecfwk_base",
    "bundle_framework:appexecfwk_core",
    "c_utils:utils",
    "ipc:ipc_single",
    "napi:ace_napi",
    "hilog:libhilog",
  ]
  part_name = "file_api"
  subsystem_name = "filemanagement"
}

ohos_source_set("js_stream_exporter_src") {
  sanitize = {
    cfi = true
    cfi_cross_dso = true
