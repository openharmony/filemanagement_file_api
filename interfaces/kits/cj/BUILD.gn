    "-flto",
  ]
  use_exceptions = true
  external_deps = [
    "ability_base:zuri",
    "ability_runtime:app_context",
    "access_token:libtokenid_sdk",
    "app_file_service:fileuri_native",
    "bundle_framework:appexecfwk_base",
    "bundle_framework:appexecfwk_core",
    "c_utils:utils",
    "ipc:ipc_single",
    "napi:ace_napi",
    "hilog:libhilog",
  ]
  part_name = "file_api"
  subsystem_name = "filemanagement"
}

ohos_source_set("js_trace_src") {
  sanitize = {
    cfi = true
    cfi_cross_dso = true
    debug = false
  }
  sources = [
    "../js/src/common/file_api_debug.cpp",
    "../js/src/common/file_fs_trace.cpp",
  ]
  public_configs = [ ":js_common_config" ]
  cflags = [
    "-fvisibility=hidden",
    "-fdata-sections",
    "-ffunction-sections",
    "-fno-asynchronous-unwind-tables",
    "-fno-unwind-tables",
    "-Oz",
  ]
  cflags_cc = [
    "-std=c++17",
    "-fvisibility-inlines-hidden",
    "-Oz",
    "-fno-rtti",
    "-fmerge-all-constants",
    "-fomit-frame-pointer",
    "-flto",
  ]
  use_exceptions = true
  external_deps = [
    "hilog:libhilog",
    "hitrace:hitrace_meter",
  ]
  part_name = "file_api"
  subsystem_name = "filemanagement"
}

ohos_shared_library("cj_file_fs_ffi") {
  include_dirs = [
    "${file_api_path}/interfaces/kits/cj/src",
    "${file_api_path}/interfaces/kits/native/remote_uri",
    "${file_api_path}/interfaces/kits/native/task_signal",
    "${file_api_path}/interfaces/kits/rust/include",
  ]

  sources = [
    "src/fdatasync.cpp",
    "src/file_ffi.cpp",
    "src/file_fs_ffi.cpp",
    "src/file_fs_impl.cpp",
    "src/file_impl.cpp",
    "src/fsync.cpp",
    "src/mkdtemp.cpp",
    "src/stat_ffi.cpp",
    "src/stat_impl.cpp",
    "src/uni_error.cpp",
    "src/utils.cpp",
  ]

  deps = [
    ":js_common_src",
    "${utils_path}/filemgmt_libhilog:filemgmt_libhilog",
    "${utils_path}/filemgmt_libn:filemgmt_libn",
  ]

  cflags_cc = [
    "-fno-exceptions",
    "-fno-threadsafe-statics",
    "-std=c++17",
    "-fno-rtti",
    "-fmerge-all-constants",
    "-fomit-frame-pointer",
    "-flto",
  ]
  use_exceptions = false
  if (use_mingw_win) {
    defines = [ "WIN_PLATFORM" ]
    sources += [ "src/file_fs_mock.cpp" ]
  } else if (use_mac) {
    defines = [ "IOS_PLATFORM" ]
    sources += [ "src/file_fs_mock.cpp" ]
  }

  external_deps = [
    "hilog:libhilog",
    "c_utils:utils",
    "napi:ace_napi",
    "napi:cj_bind_ffi",
    "napi:cj_bind_native",
  ]

  if (!use_mingw_win && !use_mac) {
    cflags = [
      "-fvisibility=hidden",
      "-fdata-sections",
      "-ffunction-sections",
      "-fno-asynchronous-unwind-tables",
      "-fno-unwind-tables",
      "-Oz",
    ]
    cflags_cc += [
      "-fvisibility-inlines-hidden",
      "-Oz",
      "-fno-rtti",
      "-fmerge-all-constants",
      "-fomit-frame-pointer",
      "-flto",
    ]
    branch_protector_ret = "pac_ret"
    sanitize = {
      integer_overflow = true
      ubsan = true
      boundary_sanitize = true
      cfi = true
      cfi_cross_dso = true
      debug = false
    }
    ldflags = [
      "-flto",
      "-Wl,--icf=all",
      "-Wl,--gc-sections",
    ]

    sources += [
      "src/copy.cpp",
      "src/copy_dir.cpp",
      "src/copy_file.cpp",
      "src/list_file.cpp",
      "src/lseek.cpp",
      "src/move_file.cpp",
      "src/randomAccessFile_impl.cpp",
      "src/readerIterator_impl.cpp",
      "src/stream_ffi.cpp",
      "src/stream_impl.cpp",
      "src/symlink.cpp",
      "src/task_signal_impl.cpp",
      "src/translistener.cpp",
      "src/watcher_impl.cpp",
      "src/xattr.cpp",
      "src/xattr_ffi.cpp",
    ]

    deps += [
      ":js_stream_exporter_src",
      ":js_trace_src",
      "${file_api_path}/interfaces/kits/js:build_kits_js",
      "${file_api_path}/interfaces/kits/js:fs",
      "${file_api_path}/interfaces/kits/native:remote_uri_native",
      "${file_api_path}/interfaces/kits/native:task_signal_native",
      "${file_api_path}/interfaces/kits/rust:rust_file",
    ]

    external_deps += [
      "ability_runtime:ability_manager",
      "ability_runtime:abilitykit_native",
      "access_token:libtokenid_sdk",
      "app_file_service:fileuri_native",
      "bounds_checking_function:libsec_shared",
      "bundle_framework:appexecfwk_base",
      "bundle_framework:appexecfwk_core",
      "data_share:datashare_common",
      "data_share:datashare_consumer",
      "dfs_service:distributed_file_daemon_kit_inner",
      "hitrace:hitrace_meter",
      "samgr:samgr_proxy",
    ]
  }

  innerapi_tags = [ "platformsdk" ]
  part_name = "file_api"
  subsystem_name = "filemanagement"
}

ohos_shared_library("cj_statvfs_ffi") {
  cflags = [
    "-fvisibility=hidden",
    "-fdata-sections",
    "-ffunction-sections",
    "-fno-asynchronous-unwind-tables",
    "-fno-unwind-tables",
    "-Oz",
  ]
